package_name: curl
name: Client URL
author: "GPM Team"

version: 1.0
description: "A Python-based implementation of the Curl utility for transferring data with URLs."

help_menu_description: {
    "url": "Remote host URL",
    "-X": "Specify request command to use",
    "-H": "Pass custom headers to server",
    "-d": "HTTP POST data",
    "-i": "Include protocol response headers in the output",
    "-L": "Follow redirects",
    "-v": "Make the operation more talkative"
}

command: curl
